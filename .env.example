# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side only (DO NOT expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Upstash Redis (Serverless Cache)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# AI Services
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Railway Microservices
RAILWAY_DISEASE_SERVICE_URL=https://your-disease-service.railway.app
RAILWAY_SATELLITE_SERVICE_URL=https://your-satellite-service.railway.app

# External Data APIs
ESOKO_API_KEY=your_esoko_api_key
NIGERIA_FARM_DATA_KEY=your_nigeria_farm_data_key

# Feature Flags
VITE_USE_MOCK_DATA=true
VITE_ENABLE_VOICE=true
VITE_ENABLE_OFFLINE=true

# App Configuration
VITE_APP_NAME=FarmFlow
VITE_APP_VERSION=1.0.0